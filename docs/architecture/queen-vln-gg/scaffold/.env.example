# --- Core ---
PORT=3000
NODE_ENV=development

# --- Auth (Passport) ---
# Fail-closed: server refuses to start without this set.
JWT_SECRET=

# GitHub OAuth (human dashboard login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://queen.vln.gg/api/auth/github/callback

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- License signing (must match packages/license-client RS256 key pair) ---
LICENSE_PRIVATE_KEY_PATH=
LICENSE_PUBLIC_KEY_PATH=

# --- Cloudflare ---
# Set once Cloudflare Access/WAF is in front of queen.vln.gg; used to verify
# the Cf-Access-Jwt-Assertion header if Access is used instead of/alongside
# the app-level Passport wall.
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=
